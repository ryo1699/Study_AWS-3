DATABASE_URL=sqlite+pysqlite:///./local.db
AWS_REGION=ap-northeast-1
IMAGE_BUCKET_NAME=your-private-image-bucket
CSV_BUCKET_NAME=your-private-csv-bucket
CSV_EXPORT_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/study-aws-3-2-csv-export
CLOUDFRONT_DOMAIN_NAME=dxxxxxxxxxxxxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXXX
CLOUDFRONT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
UPLOAD_URL_EXPIRES_SECONDS=300
VIEW_URL_EXPIRES_SECONDS=300
